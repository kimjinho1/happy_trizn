<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="HappyTrizn" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <style>
      html, body, button, input, select, textarea {
        font-family: "Pretendard Variable", Pretendard, ui-sans-serif, system-ui,
          sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
      }
    </style>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <header class="sticky top-0 z-30 bg-base-100/95 backdrop-blur border-b border-base-300 px-4 py-2 flex items-center gap-3 shadow-sm">
      <a
        href="/lobby"
        class="flex items-center gap-2 font-bold text-sm sm:text-base hover:text-primary transition shrink-0 whitespace-nowrap"
        title="로비로"
      >
        <span class="text-xl">🎮</span>
        <span>Happy Trizn</span>
      </a>
      <%= if assigns[:page_title] do %>
        <span class="text-base-content/30 hidden sm:inline">/</span>
        <span class="text-base-content/80 font-medium hidden sm:inline whitespace-nowrap truncate">
          {assigns[:page_title]}
        </span>
      <% end %>

      <div class="ml-auto flex items-center gap-1">
        <%= if user = assigns[:current_user] do %>
          <a href="/dm" class="btn btn-ghost btn-md px-2 relative" title="DM">
            💬 DM
            <% unread = HappyTrizn.Messages.unread_count(user) %>
            <%= if unread > 0 do %>
              <span class="badge badge-error badge-xs absolute -top-1 -right-1 dm-unread-badge">
                {if unread > 300, do: "300+", else: unread}
              </span>
            <% end %>
          </a>
        <% end %>
        <%= if assigns[:current_nickname] do %>
          <a href="/history" class="btn btn-ghost btn-md px-2" title="내 기록">🏆 기록</a>
          <a
            href="/settings/games"
            class="btn btn-ghost btn-md px-2"
            title="게임 옵션 (게임 중에는 모달로 열림)"
            onclick="if (window.__hasOpenSettingsBridge) { event.preventDefault(); window.dispatchEvent(new CustomEvent('phx:open-settings')); }"
          >⚙️ 옵션</a>
        <% end %>
        <%= if user = assigns[:current_user] do %>
          <div class="dropdown dropdown-end">
            <div
              tabindex="0"
              role="button"
              class="btn btn-ghost btn-md px-2 flex items-center gap-2"
              title="메뉴"
            >
              <%= if user.avatar_url do %>
                <img
                  src={user.avatar_url}
                  alt={user.nickname}
                  class="w-8 h-8 rounded-full object-cover ring-2 ring-base-300"
                />
              <% else %>
                <div class="w-8 h-8 rounded-full bg-primary/20 text-primary font-bold flex items-center justify-center ring-2 ring-base-300 text-sm">
                  {String.first(user.nickname) |> String.upcase()}
                </div>
              <% end %>
              <span class="hidden lg:inline truncate max-w-[120px]">{user.nickname}</span>
              <span class="text-sm">▾</span>
            </div>
            <ul
              tabindex="0"
              class="dropdown-content menu bg-base-100 rounded-box z-[50] w-44 p-2 shadow border border-base-300"
            >
              <li><a href="/me">👤 마이페이지</a></li>
              <li>
                <.link href={~p"/logout"} method="delete">🚪 로그아웃</.link>
              </li>
            </ul>
          </div>
        <% else %>
          <%= if guest_nick = assigns[:current_nickname] do %>
            <div class="dropdown dropdown-end">
              <div
                tabindex="0"
                role="button"
                class="btn btn-ghost btn-md px-2 flex items-center gap-2"
                title="메뉴"
              >
                <span class="hidden lg:inline truncate max-w-[140px]">(게스트) {guest_nick}</span>
                <span class="text-sm">▾</span>
              </div>
              <ul
                tabindex="0"
                class="dropdown-content menu bg-base-100 rounded-box z-[50] w-44 p-2 shadow border border-base-300"
              >
                <li>
                  <.link href={~p"/logout"} method="delete">🚪 로그아웃</.link>
                </li>
              </ul>
            </div>
          <% end %>
        <% end %>
      </div>
    </header>
    {@inner_content}
  </body>
</html>
