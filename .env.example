# Copy to .env and fill in real values. .env is gitignored.
# 주의: 같은 포트가 docker-compose.yml 과 .env 양쪽에서 동기화 됨.
#       포트 바꾸고 싶으면 여기 한 곳만 바꾸고 docker compose restart.

# Phoenix
PHX_HOST=happy.trizn.local
PORT=4000                    # 컨테이너 내부 (Phoenix bind)
PHX_PORT_HOST=4747           # 호스트 노출 포트 (UFW 룰도 이 값에 맞춤)
SECRET_KEY_BASE=             # mix phx.gen.secret (32+ chars 강제). 64자 권장.
LIVE_VIEW_SIGNING_SALT=      # openssl rand -base64 24 | tr -d '\n=+/' | head -c 32

# MySQL (Docker 내부 hostname=mysql)
MYSQL_HOST=mysql
MYSQL_PORT=4406              # 컨테이너 내부 포트. 다른 프로젝트 충돌 회피로 비표준.
MYSQL_DATABASE=happy_trizn
MYSQL_USER=root              # MySQL 8 image 가 자동 생성. MYSQL_PASSWORD 가 root 비번.
MYSQL_PASSWORD=              # 강력한 비번 (운영). dev 는 동일하게 두 곳 다 채움.
MYSQL_ROOT_PASSWORD=         # MYSQL_PASSWORD 와 같은 값으로 가능 (둘 다 root 인증).

# MongoDB (Docker 내부 hostname=mongo)
MONGO_PORT=37017             # 컨테이너 내부 포트. docker-compose 가 이 값으로 부팅.
MONGO_URL=mongodb://mongo:37017/happy_trizn   # MONGO_PORT 변경 시 같이 바꿀 것.

# Admin (단일 고정 계정, .env 로만 주입)
ADMIN_ID=admin
ADMIN_PASSWORD_HASH=         # bcrypt hash. README "시크릿 재생성" 섹션 명령 참고.
ADMIN_SESSION_SECRET=        # openssl rand -base64 24 | tr -d '\n=+/' | head -c 32

# 사내 서브넷 (UFW 룰 적용 시 참고만)
INTERNAL_SUBNET=10.0.0.0/24
