# Copy to .env and fill in real values. .env is gitignored.

# Phoenix
PHX_HOST=happy.trizn.local
PORT=4000
SECRET_KEY_BASE=             # mix phx.gen.secret 으로 생성 (64+ chars)
LIVE_VIEW_SIGNING_SALT=      # mix phx.gen.secret 16

# MySQL (Docker 내부 hostname=mysql, 컨테이너 내부 포트=3306)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=happy_trizn
MYSQL_USER=app
MYSQL_PASSWORD=              # 강력한 비번
MYSQL_ROOT_PASSWORD=         # MySQL 컨테이너 root, 운영에서만 사용

# MongoDB (Docker 내부 hostname=mongo, 컨테이너 내부 포트=27017)
MONGO_URL=mongodb://mongo:27017/happy_trizn

# Admin (단일 고정 계정, .env로만 주입)
ADMIN_ID=admin
ADMIN_PASSWORD_HASH=         # bcrypt hash. mix run -e 'IO.puts Bcrypt.hash_pwd_salt("yourpw")' 로 생성
ADMIN_SESSION_SECRET=        # mix phx.gen.secret 32

# 사내 서브넷 (UFW 룰 적용 시 참고만)
INTERNAL_SUBNET=10.0.0.0/24
