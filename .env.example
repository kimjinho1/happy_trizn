# Copy to .env and fill in real values. .env is gitignored.
# IMPORTANT: docker --env-file 은 인라인 주석 미지원. KEY=VALUE 한 줄만.
# 주석은 별도 줄에서 # 으로.

# Phoenix
# PORT: 컨테이너 내부 (Phoenix bind)
# PHX_PORT_HOST: 호스트 노출 포트 (UFW 룰도 이 값)
PHX_HOST=happy.trizn.local
PORT=4000
PHX_PORT_HOST=4747
# SECRET_KEY_BASE: mix phx.gen.secret (32+ chars). 64자 권장.
SECRET_KEY_BASE=
# LIVE_VIEW_SIGNING_SALT: openssl rand -base64 24 | tr -d '\n=+/' | head -c 32
LIVE_VIEW_SIGNING_SALT=

# MySQL (Docker 내부 hostname=mysql)
# MYSQL_PORT: 비표준 (4406) — 다른 프로젝트 충돌 회피.
# MYSQL_USER=root: MySQL 8 image 가 자동 생성. MYSQL_PASSWORD = root 비번.
MYSQL_HOST=mysql
MYSQL_PORT=4406
MYSQL_DATABASE=happy_trizn
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# MongoDB (Docker 내부 hostname=mongo)
# MONGO_PORT 변경 시 MONGO_URL 도 같이.
MONGO_PORT=37017
MONGO_URL=mongodb://mongo:37017/happy_trizn

# Admin (단일 고정 계정, .env 로만 주입)
# ADMIN_PASSWORD_HASH: bcrypt hash. README "시크릿 재생성" 섹션 참고.
ADMIN_ID=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# 사내 서브넷 (UFW 룰 참고)
INTERNAL_SUBNET=10.0.0.0/24
