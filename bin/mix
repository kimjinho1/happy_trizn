#!/usr/bin/env bash
# bin/mix - run mix commands inside the Elixir Docker container.
#
# Usage:
#   bin/mix phx.new . --app happy_trizn --module HappyTrizn --database mysql --no-install
#   bin/mix deps.get
#   bin/mix ecto.create
#   bin/mix test
#
# 로컬에 Elixir 설치 없이도 모든 mix 명령을 컨테이너 안에서 실행.
# 리포 디렉토리를 컨테이너의 /app 에 마운트해서 결과 파일이 호스트에 그대로 남음.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ELIXIR_IMAGE="${ELIXIR_IMAGE:-elixir:1.16-alpine}"

if ! docker info >/dev/null 2>&1; then
  echo "ERROR: Docker daemon not running. Start Docker Desktop first." >&2
  exit 1
fi

# TTY 자동 감지 (CI/non-interactive 환경에서도 동작)
DOCKER_TTY_FLAGS="-i"
if [ -t 0 ] && [ -t 1 ]; then
  DOCKER_TTY_FLAGS="-it"
fi

# alpine 이미지의 소수 의존성 설치 후 mix archive (phx_new) 강제 설치, 그 다음 사용자 명령 실행.
# 매번 hex/rebar 다운로드는 느리지만 별도 dev 이미지 빌드 전까지는 충분히 빠름.
docker run --rm $DOCKER_TTY_FLAGS \
  -v "$REPO_ROOT:/app" \
  -w /app \
  -e MIX_ENV="${MIX_ENV:-dev}" \
  "$ELIXIR_IMAGE" \
  sh -c "
    set -e
    apk add --no-cache --quiet git build-base openssl-dev >/dev/null 2>&1 || true
    mix local.hex --force --if-missing >/dev/null 2>&1
    mix local.rebar --force --if-missing >/dev/null 2>&1
    if ! mix archive 2>/dev/null | grep -q phx_new; then
      mix archive.install --force hex phx_new >/dev/null 2>&1
    fi
    exec mix $*
  "
